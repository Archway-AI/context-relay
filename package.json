{
  "name": "@archwayai/context-relay",
  "version": "0.1.0",
  "description": "Evidence-preserving context compression CLI for agent workflows.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/Archway-AI/context-relay#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Archway-AI/context-relay.git"
  },
  "bugs": {
    "url": "https://github.com/Archway-AI/context-relay/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "context-relay": "bin/context-relay.js"
  },
  "files": [
    ".github/ISSUE_TEMPLATE/",
    "bin/",
    "docs/architecture.md",
    "docs/eval-results.json",
    "docs/evals.md",
    "docs/limitations.md",
    "docs/releasing.md",
    "docs/security-and-privacy.md",
    "docs/trusted-publishing.md",
    "examples/",
    "fixtures/",
    "lib/",
    "scripts/",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "README.md",
    "package.json"
  ],
  "keywords": [
    "agents",
    "context",
    "cli",
    "token",
    "summaries",
    "retrieval"
  ],
  "scripts": {
    "eval": "node scripts/run-evals.js",
    "quickstart": "node scripts/quickstart.js",
    "test": "node --test",
    "pack:dry-run": "npm pack --dry-run",
    "publish:dry-run": "npm publish --dry-run --access public",
    "prepublishOnly": "npm test"
  }
}
